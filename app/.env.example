# Spotify OAuth (PKCE). Create an app: https://developer.spotify.com/dashboard
#
# Redirect URI must match the Spotify app settings exactly.
# Local dev (see vite.config.ts): http://127.0.0.1:5173/callback
# Production: https://your-domain.com/callback

VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# Optional: access-request form (https://web3forms.com). If unset, the app opens a mailto to the maintainer.
# VITE_WEB3FORMS_ACCESS_KEY=
